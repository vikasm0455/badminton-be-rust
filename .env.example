# ---- RallyUp API configuration -------------------------------------------
# Copy to .env and fill in. Only DATABASE_URL/REDIS_URL/JWT_SECRET are needed
# to boot; the rest enable email, OCR, and push.

# Postgres + Redis (docker-compose sets these for you)
DATABASE_URL=postgres://rallyup:rallyup@postgres:5432/rallyup
REDIS_URL=redis://redis:6379

# 64+ char random string — generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# The owner's email is always treated as the (single) admin.
ADMIN_EMAIL=you@example.com

# Resend (email OTP). If unset, OTP codes are printed to the server log (dev).
RESEND_API_KEY=
FROM_EMAIL=RallyUp <badminton@boyishesh.com>

# Anthropic (Claude Vision OCR for credential screenshots). If unset, OCR is
# skipped and users enter credentials manually.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Web Push — VAPID keys are auto-generated on first boot and stored in the DB.
# Just set the contact subject:
VAPID_SUBJECT=mailto:admin@boyishesh.com

# Cookies: set to true behind HTTPS / Cloudflare (production).
COOKIE_SECURE=false

# Uploads (credential screenshots, cleared nightly) + limits.
UPLOADS_PATH=/app/uploads
MAX_UPLOAD_SIZE_MB=10

# Server timezone — keep America/Los_Angeles so cron jobs run in PT.
TZ=America/Los_Angeles

# Dev only: allow the Vite/Next dev origin to call the API cross-origin.
# In production the frontend is same-origin behind Nginx, so leave empty.
ALLOWED_ORIGINS=http://localhost:3090

PORT=8090
